# ═══════════════════════════════════════════════════════════════════════════
# SmartInsure - Vehicle Insurance System Configuration
# ═══════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
# Local Development:
MONGO_URI=mongodb://localhost:27017

# MongoDB Atlas (Cloud) - Replace with your credentials:
# MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/vehicle_insurance?retryWrites=true&w=majority

# ─────────────────────────────────────────────────────────────────────────────
# JWT SECURITY (MUST CHANGE IN PRODUCTION!)
# ─────────────────────────────────────────────────────────────────────────────
# Generate a strong random string: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=smartinsure-super-secret-jwt-key-2024-change-me-to-random
JWT_ALGORITHM=HS256

# ─────────────────────────────────────────────────────────────────────────────
# TOKEN EXPIRATION (in hours/days)
# ─────────────────────────────────────────────────────────────────────────────
ADMIN_TOKEN_EXPIRE_HOURS=48
WORKER_TOKEN_EXPIRE_HOURS=3
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION SETTINGS
# ─────────────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:4200
APP_NAME=SmartInsure
FROM_NAME=SmartInsure Security

# ─────────────────────────────────────────────────────────────────────────────
# SMTP EMAIL CONFIGURATION (REQUIRED for OTP, verification, alerts)
# ─────────────────────────────────────────────────────────────────────────────
# GMAIL SETUP:
# 1. Enable 2FA: https://myaccount.google.com
# 2. Create App Password: https://myaccount.google.com/apppasswords
# 3. Select "Mail" and "Windows Computer"
# 4. Copy the 16-char password below
#
# ALTERNATIVE EMAIL PROVIDERS:
# - SendGrid: SMTP_SERVER=smtp.sendgrid.net, SMTP_USER=apikey, SMTP_PASS=<api-key>
# - Mailgun: SMTP_SERVER=smtp.mailgun.org, SMTP_USER=postmaster@<domain>, SMTP_PASS=<pwd>
# - AWS SES: SMTP_SERVER=email-smtp.region.amazonaws.com, SMTP_PORT=587

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password

# ─────────────────────────────────────────────────────────────────────────────
# REDIS CONFIGURATION (for caching and background jobs)
# ─────────────────────────────────────────────────────────────────────────────
# Local: redis://localhost:6379/0
# Render: redis://default:password@redis-host:6379/0
# REDIS_URL=redis://localhost:6379/0
