# Copy this file to .env and fill in your values
# cp .env.example .env

# MongoDB
MONGO_URI=mongodb://localhost:27017
# For Atlas: MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/vehicle_insurance

# JWT
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_64_CHARS
JWT_ALGORITHM=HS256

# Session Expiry
ADMIN_TOKEN_EXPIRE_HOURS=48
WORKER_TOKEN_EXPIRE_HOURS=3
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_URL=http://localhost:4200
APP_NAME=SmartInsure
FROM_NAME=SmartInsure Security
# Comma-separated frontend origins (Vercel URL in production)
# Example: ALLOWED_ORIGINS=https://your-app.vercel.app,https://custom-domain.com
ALLOWED_ORIGINS=http://localhost:4200

# SMTP Email (leave blank for dev/test mode — OTPs shown in API response)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Redis
REDIS_URL=redis://localhost:6379/0
