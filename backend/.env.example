# Copy this file to .env and fill in your values
# cp .env.example .env

# MongoDB
MONGO_URI=mongodb://localhost:27017
# For Atlas: MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/vehicle_insurance

# JWT
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_64_CHARS
JWT_ALGORITHM=HS256

# Session Expiry
ADMIN_TOKEN_EXPIRE_HOURS=48
WORKER_TOKEN_EXPIRE_HOURS=3
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_URL=http://localhost:4200
APP_NAME=SmartInsure
FROM_NAME=SmartInsure Security
# Comma-separated frontend origins (required for browser + separate API host)
# Example: ALLOWED_ORIGINS=https://insuradrive.vercel.app,http://localhost:4200
# Note: backend also merges localhost + https://insuradrive.vercel.app by default — add any other domains here.
ALLOWED_ORIGINS=http://localhost:4200,https://insuradrive.vercel.app

# SMTP Email (leave blank for dev/test mode — OTPs shown in API response)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Redis
REDIS_URL=redis://localhost:6379/0

# AWS S3 (optional — PDFs stored locally if not set)
AWS_S3_BUCKET=
AWS_S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
