# Copy this file to .env and fill in your values
# cp .env.example .env

# MongoDB
MONGO_URI=mongodb://localhost:27017
# For Atlas: MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/vehicle_insurance

# JWT
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_64_CHARS
JWT_ALGORITHM=HS256

# Session Expiry
ADMIN_TOKEN_EXPIRE_HOURS=48
WORKER_TOKEN_EXPIRE_HOURS=3
REFRESH_TOKEN_EXPIRE_DAYS=7

# App (must be your Vercel URL in production — used in verification/reset emails)
APP_URL=https://insuradrive.vercel.app
APP_NAME=SmartInsure
FROM_NAME=SmartInsure Security
# Comma-separated frontend origins (required for browser + separate API host)
# Example: ALLOWED_ORIGINS=https://insuradrive.vercel.app,http://localhost:4200
# Note: backend also merges localhost + https://insuradrive.vercel.app by default — add any other domains here.
ALLOWED_ORIGINS=http://localhost:4200,https://insuradrive.vercel.app

# SMTP Email (required on Render for registration OTP + password reset)
# Gmail: enable 2FA → App Password → use that 16-char password as SMTP_PASS (no spaces)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_gmail_app_password
# Optional: set SMTP_USE_SSL=true and SMTP_PORT=465 for SSL-only providers

# Redis
REDIS_URL=redis://localhost:6379/0

# AWS S3 (optional — PDFs stored locally if not set)
AWS_S3_BUCKET=
AWS_S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
